# API key harus sama dengan EKYC_FASTAPI_KEY di sekuritas-api
EKYC_AI_API_KEY=rahasia123
LIVENESS_THRESHOLD=0.80
FACE_MATCH_THRESHOLD=0.65
USE_GPU=false

# --- OCR KTP (endpoint /ocr) ---
# Nanonets-OCR-s (GGUF) di-load IN-PROCESS via llama-cpp-python (lihat
# app/services/nanonets_engine.py). Set OCR_ENGINE=stub untuk dev tanpa model.
OCR_ENGINE=nanonets
NANONETS_OCR_TEMPLATE=ktp
# false = file .gguf harus sudah ada manual di NANONETS_MODEL_PATH/NANONETS_MMPROJ_PATH.
# true = auto-download dari Hugging Face (NANONETS_REPO_ID) saat model pertama dipakai.
ALLOW_MODEL_DOWNLOADS=false
NANONETS_MODEL_PATH=./model/Nanonets-OCR-s-Q4_0.gguf
NANONETS_MMPROJ_PATH=./model/Nanonets-OCR-s-mmproj-F16.gguf
NANONETS_REPO_ID=unsloth/Nanonets-OCR-s-GGUF
NANONETS_REVISION=main
NANONETS_MODEL_FILE=Nanonets-OCR-s-Q4_0.gguf
NANONETS_MMPROJ_FILE=mmproj-F16.gguf
NANONETS_CHAT_HANDLER=qwen2.5-vl
NANONETS_CTX_SIZE=8192
NANONETS_N_GPU_LAYERS=-1
NANONETS_N_THREADS=4
NANONETS_N_BATCH=2048
NANONETS_FLASH_ATTN=true
NANONETS_USE_MMAP=true
NANONETS_USE_MLOCK=false
NANONETS_MAX_TOKENS=512
NANONETS_TEMPERATURE=0
NANONETS_VERBOSE=false
# true = model di-load saat uvicorn startup (request pertama tidak delay).
# false = lazy-load saat request /ocr atau /liveness pertama kali masuk.
NANONETS_PRELOAD_ON_START=true

# --- Selfie sambil pegang KTP (cek NIK di foto + cocokkan wajah kartu vs wajah asli) ---
# Nanonets jadi jalur UTAMA baca NIK. Tesseract (TANPA Paddle) dipakai HANYA
# sebagai fallback ringan kalau Nanonets gagal/tidak menemukan NIK 16 digit.
# Google ML Kit TIDAK dipakai di sini karena itu SDK on-device (Android/iOS),
# tidak bisa dipanggil dari backend Python.
SELFIE_KTP_CHECK_ENABLED=true
SELFIE_KTP_ENGINE=nanonets_tesseract
TESSERACT_LANG=ind+eng
# TESSERACT_CMD=/opt/homebrew/bin/tesseract   # isi manual kalau tesseract tidak kedeteksi otomatis

# --- Face match & liveness ---
FACE_MATCH_ENGINE=insightface
LIVENESS_ENGINE=silent-face-onnx
LIVENESS_MODEL_DIR=./model/liveness   # folder berisi *.onnx Silent-Face-Anti-Spoofing
